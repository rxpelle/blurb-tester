# ==============================================================================
# Trading System Environment Configuration - Phase 2
# ==============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ==============================================================================

# ==============================================================================
# REDIS CONFIGURATION
# ==============================================================================
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
FALLBACK_TO_FILES=true

# Signal ACK protocol
ACK_TIMEOUT=30000
EXECUTED_TIMEOUT=300000
MAX_SIGNAL_RETRIES=3
REDIS_HEALTH_CHECK=60000

# ==============================================================================
# PERSONAL ASSISTANT - API SERVER
# ==============================================================================
PA_PORT=8788
NODE_ENV=production

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DB_PATH=/app/data/trading_system.db

# ==============================================================================
# CRYPTO RESEARCH DAEMON
# ==============================================================================
DAEMON_ENABLED=true
CHECK_INTERVAL_MINUTES=10

# Crypto symbols to monitor (comma-separated)
CRYPTO_SYMBOLS=BTC/USD,ETH/USD,SOL/USD

# Stock symbols to monitor (comma-separated)
STOCK_SYMBOLS=AAPL,GOOGL,MSFT,TSLA

# ==============================================================================
# RISK MANAGEMENT (CRITICAL - DO NOT MODIFY WITHOUT UNDERSTANDING)
# ==============================================================================
# 2% risk per trade (NEVER exceed this)
RISK_PER_TRADE_PCT=0.02

# 10% max drawdown circuit breaker
MAX_DRAWDOWN_PCT=0.10

# 3% max daily loss limit
MAX_DAILY_LOSS_PCT=0.03

# Max 15% of equity per position
MAX_POSITION_SIZE_PCT=0.15

# Minimum 1.5:1 risk/reward ratio
MIN_RISK_REWARD_RATIO=1.5

# ==============================================================================
# CRYPTO BOT CONFIGURATION
# ==============================================================================
BOT_ID=crypto-bot-1
TRADING_MODE=live  # paper or live (CRITICAL: crypto bot reads TRADING_MODE, not BOT_MODE)

# Starting account equity
CRYPTO_ACCOUNT_EQUITY=10000

# Exchange: Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_SECRET=your_gemini_api_secret
GEMINI_SANDBOX=false  # CRITICAL: false = LIVE TRADING with real money!

# Personal Assistant callback
PA_WEBHOOK_URL=http://personal-assistant:8788/api/trading/signal/executed

# Redis subscription
REDIS_CHANNELS=signals:crypto:*

# ==============================================================================
# STOCK BOT CONFIGURATION
# ==============================================================================
STOCK_BOT_ID=stock-bot-1
STOCK_BOT_MODE=live  # paper or live

# Starting account equity
STOCK_ACCOUNT_EQUITY=10000

# Exchange: Alpaca
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://api.alpaca.markets  # Live trading

# ==============================================================================
# DASHBOARD (OPTIONAL)
# ==============================================================================
DASHBOARD_PORT=3000

# ==============================================================================
# LOGGING & DEBUGGING
# ==============================================================================
LOG_LEVEL=info  # debug, info, warn, error
DEBUG=false

# ==============================================================================
# DOCKER COMPOSE OVERRIDES
# ==============================================================================
# These can override docker-compose.yml defaults
COMPOSE_PROJECT_NAME=trading-system

# ==============================================================================
# SECURITY & ALERTS (OPTIONAL)
# ==============================================================================
# Twilio for SMS alerts (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ALERT_PHONE_NUMBER=

# Email alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# ==============================================================================
# NOTES
# ==============================================================================
# 1. Risk Management: The 2% rule is CRITICAL. Never modify without full understanding.
# 2. Paper Trading: Always test with paper trading before going live.
# 3. API Keys: Keep your API keys secure. Never commit to git.
# 4. Circuit Breakers: 10% drawdown and 3% daily loss limits protect capital.
# 5. Redis: Primary signal delivery. File-based fallback ensures reliability.
# ==============================================================================
